# ---  AUDITORIA DE NÚCLEO (REBOOT CHECK) ---
CHECK_REBOOT_NEEDED() {
    local CRITICAL_PACKAGES="linux|nvidia|mesa|ucode|systemd|wayland|xorg"
    
    
    BOOT_TIME=$(uptime -s)
    BOOT_TIMESTAMP=$(date -d "$BOOT_TIME" +%s)

    REBOOT_REQUIRED=false
    REBOOT_REASON=""

    
   while read -r line; do
       
        UPDATE_TIME=$(echo "$line" | awk '{print $1}' | tr -d '[]')
        
        UPDATE_TIMESTAMP=$(date -d "$UPDATE_TIME" +%s 2>/dev/null) || continue
        
        
        if [[ -n "$UPDATE_TIMESTAMP" && "$UPDATE_TIMESTAMP" -gt "$BOOT_TIMESTAMP" ]]; then
           
            PKG_NAME=$(echo "$line" | awk '{print $4}')
            REBOOT_REASON+="$PKG_NAME "
            REBOOT_REQUIRED=true
        fi
    done < <(grep "$(date "+%Y-%m-%d")" /var/log/pacman.log | grep -E "upgraded.*($CRITICAL_PACKAGES)")

    if [ "$REBOOT_REQUIRED" = true ]; then
        echo -e "\n${RED_NEON}[⚠️  ALERTA DE INTEGRIDADE]${NC}"
        echo -e "${YELLOW_NEON}Componentes críticos foram alterados APÓS o boot:${NC} ${WHITE_NEON}$REBOOT_REASON${NC}"
        echo -e "${PINK_NEON}>> RECOMENDAÇÃO: Reinicie o sistema para aplicar as mudanças. <<${NC}"
    fi
}



