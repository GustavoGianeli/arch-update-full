LOG_SENTINEL_DIR="$HOME/.logs_sentinel_check"
mkdir -p "$LOG_SENTINEL_DIR"

ROTATE_SENTINEL_LOGS() {
    # Mantém apenas os 3 logs mais recentes da sentinela
    local LOG_COUNT
LOG_COUNT=$(find "$LOG_SENTINEL_DIR" -maxdepth 1 -name "check_*.log" | wc -l)
    if [ "$LOG_COUNT" -ge 3 ]; then
        find "$LOG_SENTINEL_DIR" -maxdepth 1 -name "check_*.log" -type f -printf '%T@ %p\n' | sort -n | head -n 1 | cut -d' ' -f2- | xargs rm
    fi
}


CHECK_FOR_UPDATES() {
    ROTATE_SENTINEL_LOGS
    
    local LOG_FILE
    LOG_FILE="$LOG_SENTINEL_DIR/check_$(date '+%Y-%m-%d_%H-%M-%S').log"
    
    {
        echo "--- CHECK INICIADO EM: $(date) ---"
        
        local AUR_H U_PACMAN U_AUR U_FLAT U_SNAP TOTAL
        
        AUR_H=$(command -v yay || command -v paru)
        
        # 1. PACMAN - Limpeza de espaços agressiva
        U_PACMAN=$(checkupdates 2>/dev/null | wc -l | tr -d '[:space:]')
        : "${U_PACMAN:=0}"
        
        # 2. AUR
        U_AUR=0
        if [[ -n "$AUR_H" ]]; then
            U_AUR=$($AUR_H -Qu 2>/dev/null | wc -l | tr -d '[:space:]')
        fi
        : "${U_AUR:=0}"
        
        # 3. FLATPAK
        U_FLAT=0
        if command -v flatpak &>/dev/null; then
            U_FLAT=$(flatpak remote-ls --updates 2>/dev/null | wc -l | tr -d '[:space:]')
        fi
        : "${U_FLAT:=0}"

        # 4. SNAP
        U_SNAP=0
        if command -v snap &>/dev/null; then
            U_SNAP=$(snap refresh --list 2>/dev/null | grep -c '^[^Name]' | tr -d '[:space:]')
        fi
        : "${U_SNAP:=0}"

        # SOMA SEGURA
        TOTAL=$(( U_PACMAN + U_AUR + U_FLAT + U_SNAP ))

        echo "Pacman: $U_PACMAN | AUR: $U_AUR | Flatpak: $U_FLAT | Snap: $U_SNAP"
        echo "Total: $TOTAL"

        if [ "$TOTAL" -gt 0 ]; then
            notify-send -u normal -a "Arch Update Full" \
            "🛡️ SENTINELA: Reforços Detectados" \
            "Existem $TOTAL pacotes pendentes.\nExecute o Arch Update Full para atualizar."
            echo "Status: Notificação enviada ao operador."
        else
            echo "Status: Sistema atualizado. Nenhuma ação necessária."
        fi
        
        echo "--- CHECK FINALIZADO ---"
    } > "$LOG_FILE" 2>&1
}



# --- [SISTEMA] PROTOCOLO DE AUTO-INSTALAÇÃO DA SENTINELA ---
SETUP_SENTINEL() {
    local SERVICE_DIR="$HOME/.config/systemd/user"
    local SCRIPT_PATH
SCRIPT_PATH=$(realpath "$0") # Descobre onde o script está no seu SSD
    
    mkdir -p "$SERVICE_DIR"

    # Cria o arquivo de Serviço
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.service"
[Unit]
Description=Sentinela de Atualizações Arch Update Full
After=network-online.target

[Service]
Type=oneshot
ExecStart=$SCRIPT_PATH --check

[Install]
WantedBy=default.target
EOF

    # Cria o arquivo de Timer (3 horas)
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.timer"
[Unit]
Description=Roda o Sentinela a cada 3 horas

[Timer]
OnBootSec=7min
OnUnitActiveSec=3h
Persistent=true

[Install]
WantedBy=timers.target
EOF

    # Recarrega e Ativa a Sentinela no Espaço do Usuário
    systemctl --user daemon-reload
    systemctl --user enable --now arch-sentinel.timer >/dev/null 2>&1
}

