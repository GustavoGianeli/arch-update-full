# 3. ATUALIZAÇÃO DO AUR (DETECÇÃO INTELIGENTE)
status_msg "AUR_SUBSYSTEM_DETECTION"

YAY_INSTALLED=$(command -v yay)
PARU_INSTALLED=$(command -v paru)

