CHECK_FOR_UPDATES() {
   
   # --- 1. DETECГ‡ГѓO DO HELPER AUR (Prioridade YAY) ---
    if command -v yay &> /dev/null; then
        AUR_HELPER="yay"
    elif command -v paru &> /dev/null; then
        AUR_HELPER="paru"
    else
        AUR_HELPER=""
    fi
   
    # Conta atualizaГ§Гµes (Silencioso)
    U_PACMAN=$(checkupdates 2>/dev/null | wc -l)
   U_AUR=0
    if [ -n "$AUR_HELPER" ]; then
        U_AUR=$($AUR_HELPER -Qu 2>/dev/null | wc -l)
    fi
    U_FLAT=$(command -v flatpak &>/dev/null && flatpak remote-ls --updates 2>/dev/null | wc -l || echo 0)
    U_SNAP=$(command -v snap &>/dev/null && snap refresh --list 2>/dev/null | grep -c '^[^Name]' || echo 0)

    TOTAL=$((U_PACMAN + U_AUR + U_FLAT + U_SNAP))

    if [ "$TOTAL" -gt 0 ]; then
        notify-send "рџ›ЎпёЏ SENTINEL v3.6" "AtenГ§ГЈo: $TOTAL atualizaГ§Гµes pendentes.\nInicie o  script arch update full para reforГ§ar o sistema." -u normal
    fi
}

# Este bloco intercepta a chamada do Systemd Timer a cada 3 horas
if [[ "$1" == "--check" ]]; then
    # Verifica se a funГ§ГЈo existe para evitar erro de execuГ§ГЈo
    if declare -f CHECK_FOR_UPDATES > /dev/null; then
        CHECK_FOR_UPDATES
    else
     
        U_PACMAN=$(checkupdates 2>/dev/null | wc -l)
        
        
        [ -x "$(command -v yay)" ] && H="yay" || H="paru"
        U_AUR=$($H -Qu 2>/dev/null | wc -l)
        
      
        U_FLAT=$(command -v flatpak &>/dev/null && flatpak remote-ls --updates 2>/dev/null | wc -l || echo 0)
        U_SNAP=$(command -v snap &>/dev/null && snap refresh --list 2>/dev/null | grep -c '^[^Name]' || echo 0)

        TOTAL=$((U_PACMAN + U_AUR + U_FLAT + U_SNAP))

