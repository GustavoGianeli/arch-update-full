    local SCRIPT_PATH=$(realpath "$0") # Descobre onde o script estГЎ no seu SSD
    
    mkdir -p "$SERVICE_DIR"

    # Cria o arquivo de ServiГ§o
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.service"
[Unit]
Description=Sentinela de AtualizaГ§Гµes Arch Update Full
After=network-online.target

[Service]
Type=oneshot
ExecStart=$SCRIPT_PATH --check

[Install]
WantedBy=default.target
EOF

    # Cria o arquivo de Timer (3 horas)
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.timer"
[Unit]
Description=Roda o Sentinela a cada 3 horas

[Timer]
OnBootSec=10min
OnUnitActiveSec=3h
Persistent=true

[Install]
WantedBy=timers.target
EOF

    # Recarrega e Ativa a Sentinela no EspaГ§o do UsuГЎrio
    systemctl --user daemon-reload
    systemctl --user enable --now arch-sentinel.timer >/dev/null 2>&1
}

