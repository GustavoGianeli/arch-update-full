        sleep 0.5
        kill -9 "$(ps -o ppid= -p $$)"
        ;;
    [Bb]|[bb])
        echo -e "${YELLOW_NEON}[!] Sessão em modo leitura. Analise os logs.${NC}"
        echo -ne "${WHITE}Pressione ${MAGENTA_NEON}[ENTER]${NC} para encerrar o terminal...${NC}"
        read
        kill -9 $PPID
        ;;
   [Cc]|[cc])
        echo -e "${GREEN_NEON}[!] Protocolo encerrado. Invocando Shell persistente...${NC}"
        echo -e "${GRAY_NEON}------------------------------------------------------------${NC}"
        /bin/bash
        ;;
    [Dd]|[dd])
        echo -e "${RED_NEON}[!] INICIANDO PROTOCOLO DE REBOOT...${NC}"
        sleep 2
        sudo reboot
        ;;
    *)
        echo -e "${RED_NEON}[!] Opção inválida. Retornando ao prompt por segurança.${NC}"
        exit 1
        ;;
esac


