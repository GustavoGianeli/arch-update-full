#!/bin/bash

# --- PALETA DE CORES NEON ---
ASSINATURA_COR='\033[1;37m' 
NEON_BLUE='\033[1;36m' 
PINK_NEON='\033[1;35m'
GREEN_NEON='\033[1;32m'
YELLOW_NEON='\033[1;33m'
GRAY_NEON='\033[1;30m'
NC='\033[0m' 

# --- CABEÇALHO: ARCH UPDATE v3.0 ---
clear
echo -e "${NEON_BLUE}"
echo "  █████╗ ██████╗  ██████╗██╗  ██╗    ██╗   ██╗██████╗ ██████╗  █████╗ ████████╗███████╗"
echo "  ██╔══██╗██╔══██╗██╔════╝██║  ██║    ██║   ██║██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝██╔════╝"
echo "  ███████║██████╔╝██║     ███████║    ██║   ██║██████╔╝██║  ██║███████║   ██║   █████╗  "
echo "  ██╔══██║██╔══██╗██║     ██╔══██║    ██║   ██║██╔═══╝ ██║  ██║██╔══██║   ██║   ██╔══╝  "
echo "  ██║  ██║██║  ██║╚██████╗██║  ██║    ╚██████╔╝██║     ██████╔╝██║  ██║   ██║   ███████╗"
echo "  ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝     ╚═════╝ ╚═╝     ╚═════╝ ╚═╝  ╚═╝   ╚═╝   ╚══════╝"
echo -e "${PINK_NEON}  >> SYSTEM OPTIMIZATION & NEURAL LINK SYNCHRONIZATION v3.0 <<${NC}"
echo -e "${NEON_BLUE}  --------------------------------------------------------------------------------------${NC}"
sleep 1

# --- FUNÇÃO DE STATUS ---
status_msg() {
    echo -e "\n${PINK_NEON}[#]${NC} ${NEON_BLUE}EXECUTING PROTOCOL:${NC} ${YELLOW_NEON}$1${NC}"
    echo -e "${GRAY_NEON}------------------------------------------------------------${NC}"
}

# 1. OTIMIZAÇÃO DE ESPELHOS (MIRRORS)
status_msg "OPTIMIZING_NETWORK_MIRRORS"
if command -v reflector &> /dev/null; then
    echo -e "${GREEN_NEON}[BUSCANDO]${NC} Selecionando os 5 mirrors HTTPS mais rápidos..."
    sudo reflector --protocol https --latest 5 --sort rate --save /etc/pacman.d/mirrorlist
else
    echo -e "${YELLOW_NEON}[AVISO]${NC} Reflector não encontrado. Pulando otimização de rede."
fi

# 2. REPOSITÓRIOS OFICIAIS (PACMAN)
status_msg "CORE_SYSTEM_SYNCHRONIZATION (PACMAN)"
sudo pacman -Syyu --noconfirm

# 3. ATUALIZAÇÃO DO AUR (YAY)
if command -v yay &> /dev/null; then
    echo -e "\n${NEON_BLUE}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${NEON_BLUE}║${NC} ${PINK_NEON}INJECTING AUR DATA STREAMS: UPDATING AUR PACKAGES    ${NC} ${NEON_BLUE}║${NC}"
    echo -e "${NEON_BLUE}╚════════════════════════════════════════════════════════════╝${NC}"
    yay -Syu --noconfirm
fi

# 4. ATUALIZAÇÃO DE FLATPAKS (DETECÇÃO AUTOMÁTICA)
if command -v flatpak &> /dev/null; then
    echo -e "\n${PINK_NEON}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${PINK_NEON}║${NC} ${NEON_BLUE}SCANNING SANDBOX: UPDATING FLATPAK REPOSITORIES      ${NC} ${PINK_NEON}║${NC}"
    echo -e "${PINK_NEON}╚════════════════════════════════════════════════════════════╝${NC}"
    flatpak update -y
else
    echo -e "${GRAY_NEON}[INFO] Flatpak environment not detected. Skipping sector.${NC}"
fi

# 5. ATUALIZAÇÃO DE SNAPS (DETECÇÃO AUTOMÁTICA)
if command -v snap &> /dev/null; then
    echo -e "\n${YELLOW_NEON}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW_NEON}║${NC} ${NEON_BLUE}STABILIZING SNAP PACKAGES: REFRESHING ALL SNAPS       ${NC} ${YELLOW_NEON}║${NC}"
    echo -e "${YELLOW_NEON}╚════════════════════════════════════════════════════════════╝${NC}"
    sudo snap refresh
else
    echo -e "${GRAY_NEON}[INFO] Snap environment not detected. Skipping sector.${NC}"
fi

# 6. LIMPEZA DE ÓRFÃOS
status_msg "PURGING_RESIDUAL_FRAGMENTS (ORPHANS)"
ORPHANS=$(pacman -Qdtq)
if [ -n "$ORPHANS" ]; then
    sudo pacman -Rns $ORPHANS --noconfirm
    echo -e "${GREEN_NEON}[SUCCESS]${NC} Residual data erased."
else
    echo -e "${YELLOW_NEON}[INFO]${NC} No fragments found in sectors."
fi

# 7. LIMPEZA DO CACHE
status_msg "STABILIZING_CACHE_RESERVES (PACCACHE)"
if command -v paccache &> /dev/null; then
    sudo paccache -r
else
    sudo pacman -Sc --noconfirm
fi

# --- FINALIZAÇÃO ---
echo -e "\n${NEON_BLUE}--------------------------------------------------------------------------------------${NC}"
echo -e "${GREEN_NEON}   [!] ARCH UPDATE PROTOCOL COMPLETE: YOUR SYSTEM IS NOW REINFORCED [!]${NC}"
echo -e "${PINK_NEON}   >> STATUS: SECURE | ENCRYPTED | OPTIMIZED <<${NC}"
echo -e "${NEON_BLUE}--------------------------------------------------------------------------------------${NC}"

echo ""
echo -e "      ${ASSINATURA_COR}© [2026] ARCH UPDATER PROTOCOL | by Gustavo Gianeli/Sétimo${NC}"
echo ""

## --- PROTOCOLO DE ENCERRAMENTO INTERATIVO v4.0 ---
echo -e "\n${CYAN_NEON}--------------------------------------------------------------------------------------${NC}"
echo -e "${GREEN_NEON}   [!] ARCH UPDATE PROTOCOL COMPLETE: YOUR SYSTEM IS NOW REINFORCED [!]${NC}"
echo -e "${MAGENTA_NEON}   >> STATUS: SECURE | O QUE DESEJA FAZER AGORA ? <<${NC}"
echo -e "${CYAN_NEON}--------------------------------------------------------------------------------------${NC}"

echo -e "${MAGENTA_NEON}(A)${NC} ${WHITE}Encerrar sessão e fechar terminal${NC} ${GRAY}(Kill Switch)${NC}"
echo -e "${MAGENTA_NEON}(B)${NC} ${WHITE}Encerrar sessão (Modo Leitura)${NC} ${GRAY}(Buffer de Segurança)${NC}"
echo -e "${MAGENTA_NEON}(C)${NC} ${WHITE}Continuar na sessão${NC} ${GRAY}(Return to Prompt)${NC}"
echo -e "${RED_NEON}(D)${NC} ${WHITE}Reiniciar o sistema${NC} ${GRAY}(Reboot Protocol)${NC}"
echo ""
echo -ne "${CYAN_NEON}[ESCOLHA]:${NC} "
read -n 1 OPCAO
echo ""

case $OPCAO in
    [Aa]|[aa])
        echo -e "${RED_NEON}[!] Encerrando conexão e fechando hardware...${NC}"
        sleep 0.5
        kill -9 "$(ps -o ppid= -p $$)"
        ;;
    [Bb]|[bb])
        echo -e "${YELLOW_NEON}[!] Sessão em modo leitura. Analise os logs.${NC}"
        echo -ne "${WHITE}Pressione ${MAGENTA_NEON}[ENTER]${NC} para encerrar o terminal...${NC}"
        read
        kill -9 $PPID
        ;;
   [Cc]|[cc])
        echo -e "${GREEN_NEON}[!] Protocolo encerrado. Invocando Shell persistente...${NC}"
        echo -e "${GRAY_NEON}------------------------------------------------------------${NC}"
        # Esta linha é o segredo: ela abre um novo Bash dentro da mesma janela
        # e mantém você nela mesmo que o script original tenha acabado.
        /bin/bash
        ;;
    [Dd]|[dd])
        echo -e "${RED_NEON}[!] INICIANDO PROTOCOLO DE REBOOT...${NC}"
        sleep 2
        sudo reboot
        ;;
    *)
        echo -e "${RED_NEON}[!] Opção inválida. Retornando ao prompt por segurança.${NC}"
        exit 1
        ;;
esac


