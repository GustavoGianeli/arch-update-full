echo -e "${YELLOW_NEON}║${NC} ${NEON_BLUE}INTEGRITY SCAN: DO YOU WANT TO AUDIT SYSTEM FILES?        ${NC} ${YELLOW_NEON}║${NC}"
echo -e "${YELLOW_NEON}╚════════════════════════════════════════════════════════════╝${NC}"
read -p "(s/N): " escolha_auditoria

if [[ "$escolha_auditoria" =~ ^[Ss]$ ]]; then
    status_msg "SYSTEM_INTEGRITY_CHECK"
    echo -e "${YELLOW_NEON}[AUDITANDO]${NC} O Sétimo está verificando as digitais do Arch..."
    
   
    lista_real=$(sudo pacman -Qkk 2>&1 | grep -E "[1-9][0-9]* arquivo(s)? alterado(s)?|mismatch|inconsistente")
    
    if [ -n "$lista_real" ]; then
        echo -e "\n${PINK_NEON}[ALERTA]${NC} Foi detectado que arquivos foram alterados:"
        echo -e "${GRAY_NEON}--------------------------------------------------------${NC}"
