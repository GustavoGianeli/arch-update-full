# ---  VERIFICAÇÃO DE ESPAÇO EM DISCO ---
CHECK_DISK_SPACE() {
    
    TEXTO_DISK=" ANALYZING STORAGE: CHECKING DISK INTEGRITY RESERVE"
    TAM_TEXTO=${#TEXTO_DISK}
    ESPACOS=$((LARGURA_BOX - TAM_TEXTO - 2))


    echo -e "\n${NEON_BLUE}╔$(printf '═%.0s' $(seq 1 $((LARGURA_BOX-2))))╗${NC}"
    printf "${NEON_BLUE}║${NC}${PINK_NEON}%s%*s${NC}${NEON_BLUE}║${NC}\n" "$TEXTO_DISK" "$ESPACOS" ""
    echo -e "${NEON_BLUE}╚$(printf '═%.0s' $(seq 1 $((LARGURA_BOX-2))))╝${NC}"

    FREE_SPACE=$(df -BG / | awk 'NR==2 {print $4}' | sed 's/G//')
    
    

    if [ "$FREE_SPACE" -lt 5 ]; then
        echo -e "${RED_NEON}[CRÍTICO] Espaço insuficiente: Apenas ${FREE_SPACE}GB livres.${NC}"
        echo -e "${YELLOW_NEON}[SUGESTÃO] Limpando cache do pacman para tentar liberar espaço...${NC}"
        sudo paccache -rk 1
        
       
        FREE_SPACE=$(df -BG / | awk 'NR==2 {print $4}' | sed 's/G//')
        if [ "$FREE_SPACE" -lt 5 ]; then
            echo -e "${RED_NEON}[ERRO FATAL] Espaço ainda insuficiente (${FREE_SPACE}GB). Abortando para evitar corrupção.${NC}"
            echo "[LOG] Abortando por falta de espaço em $(date)" >> "$LOG_ATUAL"
            exit 1
        fi
    else
        echo -e "${GREEN_NEON}[OK]${NC} Reserva de disco confirmada: ${FREE_SPACE}GB disponíveis."
    fi
}

