    echo -e "${YELLOW_NEON}║${NC} ${NEON_BLUE}STABILIZING SNAP PACKAGES: REFRESHING ALL SNAPS       ${NC} ${YELLOW_NEON}║${NC}"
    echo -e "${YELLOW_NEON}╚════════════════════════════════════════════════════════════╝${NC}"
    sudo snap refresh
else
    echo -e "${GRAY_NEON}[INFO] Snap environment not detected. Skipping sector.${NC}"
fi

# ---  AUDITORIA DE NÚCLEO (REBOOT CHECK) ---
CHECK_REBOOT_NEEDED() {
    
    local CRITICAL_PACKAGES="linux|nvidia|mesa|ucode|systemd|wayland|xorg"
    
    TODAY=$(date "+%Y-%m-%d")
    REBOOT_REASON=$(grep "$TODAY" /var/log/pacman.log | grep -E "upgraded ($CRITICAL_PACKAGES)" | awk '{print $4}' | sort -u | tr '\n' ' ')

    if [ -n "$REBOOT_REASON" ]; then
        echo -e "\n${RED_NEON}[⚠️  ALERTA DE INTEGRIDADE]${NC}"
        echo -e "${YELLOW_NEON}Componentes críticos foram alterados:${NC} ${WHITE_NEON}$REBOOT_REASON${NC}"
        echo -e "${PINK_NEON}>> RECOMENDAÇÃO: Reinicie o sistema imediatamente para carregar os novos drivers/kernel.${NC}"
        REBOOT_REQUIRED=true
    else
        REBOOT_REQUIRED=false
    fi
}


CHECK_REBOOT_NEEDED


# 6. LIMPEZA DE ÓRFÃOS
status_msg "PURGING_RESIDUAL_FRAGMENTS (ORPHANS)"
ORPHANS=$(pacman -Qdtq)
if [ -n "$ORPHANS" ]; then
    sudo pacman -Rns $ORPHANS --noconfirm
