echo -e "${MAGENTA_NEON}   >> STATUS: SECURE | O QUE DESEJA FAZER AGORA ? <<${NC}"
echo -e "${CYAN_NEON}--------------------------------------------------------------------------------------${NC}"

# --- NOTIFICAГ‡ГѓO UNIVERSAL (SINALIZAГ‡ГѓO VISUAL) ---
NOTIFY_FINISH() {
    
    if command -v notify-send >/dev/null 2>&1; then
        notify-send -u critical -a "Arch Update Full" \
        "рџ›ЎпёЏ PROTOCOLO CONCLUГЌDO" \
        "O sistema foi reforГ§ado com sucesso.\nLog: .logs_arch_update_full"
    else
       
        echo -e "${YELLOW_NEON}[AVISO]${NC} UtilitГЎrio de notificaГ§ГЈo nГЈo encontrado. Pulando alerta visual."
    fi
}


# --- [SISTEMA] NOTIFICAГ‡ГѓO E AUDITORIA FINAL ---
NOTIFY_FINISH

# Chama a funГ§ГЈo que criamos para escanear o log do Pacman
CHECK_REBOOT_NEEDED

echo -e "\n${GRAY_NEON}------------------------------------------------------------${NC}"
echo -e "${CYAN_NEON}              MENU DE ENCERRAMENTO - v3.6${NC}"
echo -e "${GRAY_NEON}------------------------------------------------------------${NC}"

echo -e "${MAGENTA_NEON}(A)${NC} ${WHITE}Encerrar sessГЈo e fechar terminal${NC} ${CYAN_NEON}(Kill Switch)${NC}"
echo -e "${MAGENTA_NEON}(B)${NC} ${WHITE}Encerrar sessГЈo (Modo Leitura)${NC} ${CYAN_NEON}(Buffer de SeguranГ§a)${NC}"
echo -e "${MAGENTA_NEON}(C)${NC} ${WHITE}Continuar na sessГЈo${NC} ${CYAN_NEON}(Return to Prompt)${NC}"


if [ "$REBOOT_REQUIRED" = true ]; then
    echo -e "${RED_NEON}(D) [RECOMENDADO] Reiniciar o sistema (Reboot Protocol)${NC}"
else
    echo -e "${MAGENTA_NEON}(D)${NC} ${WHITE}Reiniciar o sistema${NC} ${CYAN_NEON}(Reboot Protocol)${NC}"
fi

echo ""
echo -ne "${CYAN_NEON}[ESCOLHA]:${NC} "
read -n 1 OPCAO
echo ""

case $OPCAO in
    [Aa]|[aa])
        echo -e "${RED_NEON}[!] Encerrando conexГЈo e fechando hardware...${NC}"
        sleep 0.5
        kill -9 "$(ps -o ppid= -p $$)"
        ;;
    [Bb]|[bb])
        echo -e "${YELLOW_NEON}[!] SessГЈo em modo leitura. Analise os logs.${NC}"
        echo -ne "${WHITE}Pressione ${MAGENTA_NEON}[ENTER]${NC} para encerrar o terminal...${NC}"
        read
        kill -9 $PPID
        ;;
   [Cc]|[cc])
        echo -e "${GREEN_NEON}[!] Protocolo encerrado. Invocando Shell persistente...${NC}"
        echo -e "${GRAY_NEON}------------------------------------------------------------${NC}"
        /bin/bash
        ;;
    [Dd]|[dd])
        echo -e "${RED_NEON}[!] INICIANDO PROTOCOLO DE REBOOT...${NC}"
        sleep 2
        sudo reboot
        ;;
    *)
        echo -e "${RED_NEON}[!] OpГ§ГЈo invГЎlida. Retornando ao prompt por seguranГ§a.${NC}"
        exit 1
        ;;
esac


