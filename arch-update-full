# FunГ§ГЈo para Limpeza (FIFO - Keep 7)
rotate_logs() {
    
    LOG_COUNT=$(ls -1 "$LOG_DIR"/update_*.log 2>/dev/null | wc -l)
    
    if [ "$LOG_COUNT" -ge 7 ]; then
      
