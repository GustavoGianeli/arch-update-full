# --- CONFIGURAÇÃO DE LOGS ROTATIVOS ---
LOG_DIR="$HOME/.logs_arch_update_full"
mkdir -p "$LOG_DIR"  

DATA_LOG=$(date "+%Y-%m-%d_%H-%M-%S")
LOG_ATUAL="$LOG_DIR/update_$DATA_LOG.log"

# Função para Limpeza (FIFO - Keep 7)
rotate_logs() {
    
    LOG_COUNT=$(ls -1 "$LOG_DIR"/update_*.log 2>/dev/null | wc -l)
    
    if [ "$LOG_COUNT" -ge 7 ]; then
      
        OLD_LOG=$(ls -1t "$LOG_DIR"/update_*.log | tail -n 1)
        rm "$OLD_LOG"
        echo -e "${GRAY_NEON}[LOG_SYSTEM] Ciclo de rotação ativo. Log antigo removido: $(basename "$OLD_LOG")${NC}"
    fi
}


rotate_logs


exec > >(tee -i "$LOG_ATUAL") 2>&1

echo -e "${GRAY_NEON}--- INICIANDO REGISTRO DE SESSÃO: $DATA_LOG ---${NC}"


# --- [SISTEMA] PROTOCOLO DE AUTO-INSTALAÇÃO DA SENTINELA ---
SETUP_SENTINEL() {
    local SERVICE_DIR="$HOME/.config/systemd/user"
    local SCRIPT_PATH=$(realpath "$0") # Descobre onde o script está no seu SSD
    
    mkdir -p "$SERVICE_DIR"

    # Cria o arquivo de Serviço
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.service"
[Unit]
Description=Sentinela de Atualizações Arch Update Full
After=network-online.target

[Service]
Type=oneshot
ExecStart=$SCRIPT_PATH --check

[Install]
WantedBy=default.target
EOF

    # Cria o arquivo de Timer (12 horas)
    cat <<EOF > "$SERVICE_DIR/arch-sentinel.timer"
[Unit]
Description=Roda o Sentinela a cada 12 horas

[Timer]
OnBootSec=10min
OnUnitActiveSec=12h
Persistent=true

[Install]
WantedBy=timers.target
EOF

    # Recarrega e Ativa a Sentinela no Espaço do Usuário
    systemctl --user daemon-reload
    systemctl --user enable --now arch-sentinel.timer >/dev/null 2>&1
}

# Executa o instalador (ele só atualiza os arquivos se o script mudar de lugar)
