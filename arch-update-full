    else
        echo -e "\n${GREEN_NEON}[LIMPO]${NC} Integridade 100%. Nenhuma alteração suspeita."
    fi
else
    echo -e "${RED_NEON}[PULADO]${NC} Auditoria ignorada pelo operador."
fi

