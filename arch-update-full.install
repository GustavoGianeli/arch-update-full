post_install() {
    echo -e "\n\e[1;36m[SENTINEL INFO]\e[0m Se você utiliza GNOME e suas extensões forem desativadas,"
    echo -e "\e[1;36m[SENTINEL INFO]\e[0m basta reativá-las no app 'Extensões' ou via terminal:"
    echo -e "\e[1;33m  gsettings set org.gnome.shell disable-user-extensions false\e[0m\n"
}

post_upgrade() {
    post_install
}
